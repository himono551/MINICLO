{
  "manifest_version": 3,
  "name": "Monodata Sheet Capture",
  "description": "Capture product info from the current page and append to Google Sheets via Apps Script.",
  "version": "1.1.0",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
